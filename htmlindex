<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Kunal Kumar - AI & Full Stack Developer</title>
    
    <!-- Tailwind CSS (CDN for development only) -->
    <script>
        // Suppress Tailwind CDN warning
        if (typeof console !== 'undefined' && console.warn) {
            const originalWarn = console.warn;
            console.warn = function(...args) {
                if (args[0] && typeof args[0] === 'string' && args[0].includes('tailwindcss.com')) {
                    return; // Suppress Tailwind CDN warning
                }
                originalWarn.apply(console, args);
            };
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Fira+Code:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <style>
        /* Custom CSS for portfolio */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Tajawal', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #e2e8f0;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* Loading Screen */
        .loader-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0f172a;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity 0.5s ease;
        }
        
        .loader-content {
            text-align: center;
            max-width: 500px;
            width: 90%;
        }
        
        .loader-code-text {
            font-family: 'Fira Code', monospace;
            font-size: 1.2rem;
            color: #60a5fa;
            margin-bottom: 2rem;
            text-align: left;
        }
        
        .code-line {
            margin-bottom: 0.5rem;
            opacity: 0;
            transform: translateY(10px);
        }
        
        .code-keyword {
            color: #f472b6;
        }
        
        .code-string {
            color: #34d399;
        }
        
        .loader-spinner-wrapper {
            margin: 2rem auto;
            width: 80px;
            height: 80px;
        }
        
        .loader-spinner {
            width: 100%;
            height: 100%;
            border: 4px solid #1e293b;
            border-top-color: #60a5fa;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .loader-progress-wrapper {
            height: 4px;
            background: #1e293b;
            border-radius: 2px;
            overflow: hidden;
            margin: 2rem 0;
        }
        
        .loader-progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #60a5fa 0%, #3b82f6 100%);
            width: 0%;
            transition: width 0.3s ease;
        }
        
        .loader-percentage {
            font-family: 'Fira Code', monospace;
            font-size: 1.5rem;
            color: #60a5fa;
        }
        
        /* Header */
        .main-header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 1rem 0;
        }
        
        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .brand-logo {
            font-family: 'Fira Code', monospace;
            font-size: 1.8rem;
            font-weight: bold;
        }
        
        .logo-bracket {
            color: #60a5fa;
        }
        
        .logo-text {
            color: #e2e8f0;
            margin: 0 0.3rem;
        }
        
        .nav-menu {
            display: flex;
            gap: 2rem;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.3s ease;
            padding: 0.5rem 1rem;
            border-radius: 8px;
        }
        
        .nav-link:hover,
        .nav-link.active {
            color: #60a5fa;
            background: rgba(96, 165, 250, 0.1);
        }
        
        .nav-controls {
            display: flex;
            gap: 1rem;
            align-items: center;
        }
        
        .lang-toggle,
        .theme-toggle,
        .menu-toggle {
            background: none;
            border: 1px solid #334155;
            color: #94a3b8;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .lang-toggle:hover,
        .theme-toggle:hover {
            border-color: #60a5fa;
            color: #60a5fa;
        }
        
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 4px;
        }
        
        .menu-toggle span {
            width: 20px;
            height: 2px;
            background: #94a3b8;
            transition: 0.3s;
        }
        
        /* Hero Section */
        .hero-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            padding-top: 80px;
        }
        
        .hero-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }
        
        .hero-greeting {
            font-size: 1.5rem;
            color: #94a3b8;
            margin-bottom: 1rem;
            font-family: 'Fira Code', monospace;
        }
        
        .greeting-cursor {
            color: #60a5fa;
            animation: blink 1s infinite;
        }
        
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
        
        .hero-name {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            font-family: 'Fira Code', monospace;
        }
        
        .name-prefix {
            color: #f472b6;
        }
        
        .name-operator {
            color: #94a3b8;
            margin: 0 0.5rem;
        }
        
        .name-value {
            color: #60a5fa;
        }
        
        .name-suffix {
            color: #94a3b8;
        }
        
        .hero-title {
            font-size: 1.8rem;
            color: #94a3b8;
            margin-bottom: 1.5rem;
            font-family: 'Fira Code', monospace;
        }
        
        .title-prefix {
            color: #64748b;
        }
        
        .title-text {
            color: #cbd5e1;
            margin-left: 0.5rem;
        }
        
        .hero-description {
            font-size: 1.1rem;
            line-height: 1.6;
            color: #94a3b8;
            margin-bottom: 2rem;
            max-width: 500px;
        }
        
        .hero-buttons {
            display: flex;
            gap: 1rem;
            margin-bottom: 3rem;
        }
        
        .btn {
            padding: 0.8rem 2rem;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(96, 165, 250, 0.3);
        }
        
        .btn-secondary {
            border: 2px solid #60a5fa;
            color: #60a5fa;
            background: transparent;
        }
        
        .btn-secondary:hover {
            background: rgba(96, 165, 250, 0.1);
            transform: translateY(-2px);
        }
        
        .hero-social {
            display: flex;
            gap: 1rem;
        }
        
        .social-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: rgba(96, 165, 250, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #60a5fa;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .social-icon:hover {
            background: #60a5fa;
            color: white;
            transform: translateY(-3px);
        }
        
        .hero-image-wrapper {
            position: relative;
        }
        
        .hero-image-container {
            position: relative;
            width: 400px;
            height: 400px;
            margin: 0 auto;
        }
        
        .profile-image-glow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(96, 165, 250, 0.2) 0%, transparent 70%);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 0.8; }
        }
        
        .profile-image-frame {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
            padding: 8px;
        }
        
        .profile-image {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            overflow: hidden;
            background: #1e293b;
        }
        
        .profile-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .profile-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #1e293b;
            color: #60a5fa;
            font-size: 4rem;
        }
        
        .floating-badge {
            position: absolute;
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(96, 165, 250, 0.3);
            border-radius: 12px;
            padding: 0.8rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            animation: float 6s ease-in-out infinite;
            z-index: 10;
        }
        
        .badge-1 {
            top: 20px;
            right: 0;
            animation-delay: 0s;
        }
        
        .badge-2 {
            bottom: 50px;
            left: 0;
            animation-delay: 2s;
        }
        
        .badge-3 {
            bottom: 20px;
            right: 30px;
            animation-delay: 4s;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        .floating-badge i {
            font-size: 1.5rem;
            color: #60a5fa;
        }
        
        .badge-content {
            display: flex;
            flex-direction: column;
        }
        
        .badge-title {
            font-weight: 600;
            color: #e2e8f0;
            font-size: 0.9rem;
        }
        
        .badge-libs {
            font-size: 0.8rem;
            color: #94a3b8;
        }
        
        .scroll-indicator {
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }
        
        .scroll-mouse {
            width: 30px;
            height: 50px;
            border: 2px solid #60a5fa;
            border-radius: 15px;
            position: relative;
        }
        
        .scroll-wheel {
            width: 4px;
            height: 10px;
            background: #60a5fa;
            border-radius: 2px;
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            animation: scroll 2s infinite;
        }
        
        @keyframes scroll {
            0% { top: 10px; opacity: 1; }
            100% { top: 30px; opacity: 0; }
        }
        
        .scroll-text {
            color: #94a3b8;
            font-size: 0.9rem;
        }
        
        /* Sections */
        .section {
            padding: 100px 0;
            position: relative;
        }
        
        .section-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        
        .section-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 4rem;
        }
        
        .section-number {
            font-family: 'Fira Code', monospace;
            font-size: 1.2rem;
            color: #60a5fa;
            opacity: 0.7;
        }
        
        .section-title {
            font-family: 'Fira Code', monospace;
            font-size: 2.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .title-bracket {
            color: #60a5fa;
        }
        
        .title-text {
            color: #e2e8f0;
        }
        
        .section-line {
            flex: 1;
            height: 2px;
            background: linear-gradient(90deg, #60a5fa 0%, transparent 100%);
        }
        
        /* About Section */
        .about-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }
        
        .about-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #94a3b8;
            margin-bottom: 2rem;
        }
        
        .about-details {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        
        .detail-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: #cbd5e1;
        }
        
        .detail-item i {
            color: #60a5fa;
            width: 20px;
        }
        
        .about-stats {
            display: flex;
            gap: 3rem;
            margin-top: 3rem;
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 3rem;
            font-weight: 800;
            color: #60a5fa;
            font-family: 'Fira Code', monospace;
            line-height: 1;
        }
        
        .stat-label {
            color: #94a3b8;
            margin-top: 0.5rem;
            font-size: 0.9rem;
        }
        
        .about-image-container {
            background: rgba(30, 41, 59, 0.5);
            border-radius: 20px;
            padding: 2rem;
            border: 1px solid rgba(96, 165, 250, 0.2);
            backdrop-filter: blur(10px);
        }
        
        .code-block {
            font-family: 'Fira Code', monospace;
            font-size: 1rem;
            color: #cbd5e1;
            line-height: 1.8;
        }
        
        .code-line {
            margin-bottom: 0.5rem;
        }
        
        .indent {
            padding-left: 2rem;
        }
        
        .code-property {
            color: #60a5fa;
        }
        
        .code-comma,
        .code-semicolon {
            color: #94a3b8;
        }
        
        .code-brace,
        .code-bracket {
            color: #f472b6;
        }
        
        /* Skills Section */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }
        
        .skill-category {
            background: rgba(30, 41, 59, 0.5);
            border-radius: 15px;
            padding: 2rem;
            border: 1px solid rgba(96, 165, 250, 0.2);
        }
        
        .category-title {
            color: #e2e8f0;
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid rgba(96, 165, 250, 0.3);
        }
        
        .skill-items {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        
        .skill-item {
            position: relative;
        }
        
        .skill-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
        }
        
        .skill-name {
            color: #cbd5e1;
            font-weight: 600;
        }
        
        .skill-percent {
            color: #60a5fa;
            font-family: 'Fira Code', monospace;
            font-weight: 600;
        }
        
        .skill-bar {
            height: 8px;
            background: rgba(96, 165, 250, 0.1);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .skill-progress {
            height: 100%;
            background: linear-gradient(90deg, #60a5fa 0%, #3b82f6 100%);
            width: 0%;
            border-radius: 4px;
            transition: width 1.5s ease-in-out;
        }
        
        /* Experience Section */
        .timeline {
            position: relative;
            max-width: 800px;
            margin: 0 auto;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 30px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #60a5fa 0%, transparent 100%);
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 3rem;
            padding-left: 80px;
        }
        
        .timeline-marker {
            position: absolute;
            left: 20px;
            top: 0;
            width: 20px;
            height: 20px;
            border: 3px solid #60a5fa;
            background: #0f172a;
            border-radius: 50%;
            z-index: 1;
        }
        
        .timeline-content {
            background: rgba(30, 41, 59, 0.5);
            border-radius: 15px;
            padding: 2rem;
            border: 1px solid rgba(96, 165, 250, 0.2);
            position: relative;
        }
        
        .timeline-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        
        .timeline-year {
            color: #60a5fa;
            font-weight: 600;
            font-family: 'Fira Code', monospace;
        }
        
        .timeline-badge {
            background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
            color: white;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        
        .timeline-title {
            color: #e2e8f0;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        
        .timeline-company {
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }
        
        .timeline-description {
            color: #94a3b8;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        
        .timeline-achievements {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            margin-bottom: 1.5rem;
        }
        
        .achievement-item {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            color: #cbd5e1;
        }
        
        .achievement-item i {
            color: #34d399;
        }
        
        .timeline-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        
        .tag {
            background: rgba(96, 165, 250, 0.1);
            color: #60a5fa;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-family: 'Fira Code', monospace;
        }
        
        /* Projects Section */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
        }
        
        .project-card {
            background: rgba(30, 41, 59, 0.5);
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid rgba(96, 165, 250, 0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .project-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }
        
        .project-image {
            height: 200px;
            background: #1e293b;
            position: relative;
            overflow: hidden;
        }
        
        .project-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .project-card:hover .project-overlay {
            opacity: 1;
        }
        
        .project-links {
            display: flex;
            gap: 1rem;
        }
        
        .project-link {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #60a5fa;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: transform 0.3s ease;
        }
        
        .project-link:hover {
            transform: scale(1.1);
        }
        
        .project-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: #60a5fa;
        }
        
        .project-content {
            padding: 1.5rem;
        }
        
        .project-title {
            color: #e2e8f0;
            font-size: 1.3rem;
            margin-bottom: 0.8rem;
        }
        
        .project-description {
            color: #94a3b8;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        
        .project-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        
        /* Contact Section */
        .contact-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
        }
        
        .contact-info {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }
        
        .contact-item {
            display: flex;
            gap: 1.5rem;
            align-items: flex-start;
        }
        
        .contact-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(96, 165, 250, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #60a5fa;
            font-size: 1.2rem;
            flex-shrink: 0;
        }
        
        .contact-details {
            flex: 1;
        }
        
        .contact-label {
            color: #cbd5e1;
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }
        
